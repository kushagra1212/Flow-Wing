type obj = {
    i:int,
    s:str
  }
type k = {
  o: int,
  s: str,
  d: deci,
  i: int,
  ob:obj
}
type par = {
  u: str,
  g: k[2]
}
type t = {
  x: int,
  y: str,
  a: deci,
  b: bool,
  ar: par[1]
}
var gka: k  = {
  i:1022,
 o: 102,
  s: "sora"
  
}

var arr:t[2] = [{x:2,y:"hello",a:3.3,b:true,ar:[{u:"get",g:[gka]}]}]
var sec:t[3] = [{a:3.5,ar:[{g:[{s:"god",i:12,ob:{s:"some",i:200}}]}]}]

fun getOne(ar:t)->t{
  ar.x = 100
  ar.y = "Hello2"
  ar.a = 5.4
  ar.b = true 
  ar.ar = [1 fill {g:[{d:43.3,s:"go"},{ob:{s:"hi",i:20}}]}]
  return ar
}

fun getTwo(ar:t)->t{
  ar.x = 200
  ar.y = "Hello4"
  ar.b = false 
  ar.ar = [{g:[{d:55.3,},{ob:{s:"bye",i:40}}]}]
  return ar
}


print(arr)
print("\n")
var tm:t = getOne(getTwo(arr[0]))
print(tm)
