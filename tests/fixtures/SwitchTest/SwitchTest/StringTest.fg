bring text

var a:str = "s"

switch a {
    case "s":{
        print("Print s")
    }
    case "d":{
        print("Print d")
    }default: {
        print("default")
    }
}

var mode: str = "upper"
var sample: str = "jSsHs"

switch mode {
    case "upper":{
        print("\nUpper=" + text::toUpper(sample))
    }
    case "lower":{
        print("\nLower=" + text::toLower(sample))
    }default: {
        print("\nmode-default")
    }
}

mode = "length"
switch mode {
    case "length":{
        print("\nLength=" + text::getLength(sample))
    }
    case "trim":{
        print("\nTrim=" + text::trim("  hill "))
    }default: {
        print("\nmode-default")
    }
}

mode = "lower"
switch mode {
    case "lower":{
        print("\nLower=" + text::toLower(sample))
    }
    default: {
        print("\nmode-default")
    }
}

mode = "trim"
switch mode {
    case "trim":{
        print("\nTrim=" + text::trim("  hill "))
    }
    default: {
        print("\nmode-default")
    }
}

mode = "replace"
switch mode {
    case "replace":{
        print("\nReplace=" + text::replace("hello", "l", "x"))
    }
    default: {
        print("\nmode-default")
    }
}

mode = "reverse"
switch mode {
    case "reverse":{
        print("\nReverse=" + text::reverse("CBA"))
    }
    default: {
        print("\nmode-default")
    }
}

var indexed: str = "hello"
indexed[2] = 's'
print("\nIndexWrite=" + indexed)
print("\nIndexRead=" + indexed[2])

var objectSample: text::Text = new text::Text("  hill ")
print("\nObjLength=" + objectSample.getLength())
print("\nObjAt=" + objectSample.at(3))
var trimObject: text::Text = new text::Text("  hill ")
print("\nObjTrim=" + trimObject.trim().get())
var chainObject: text::Text = new text::Text("abc")
print("\nObjChain=" + chainObject.toUpper().reverse().get())
