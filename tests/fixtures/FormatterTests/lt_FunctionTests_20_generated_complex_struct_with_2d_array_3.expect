type Matrix_3 = {
    rows: int[4][2]
    valid: bool
}
fun getMatrix(v: int) -> Matrix_3 {
    var m: Matrix_3
    m.valid = true
    m.rows[0][0] = v
    return m
}
var mat: Matrix_3 = getMatrix(300)
println(mat.valid)
println(mat.rows[0][0])
