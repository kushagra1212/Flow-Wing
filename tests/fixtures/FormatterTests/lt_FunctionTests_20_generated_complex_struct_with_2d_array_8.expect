type Matrix_8 = {
    rows: int[9][2]
    valid: bool
}
fun getMatrix(v: int) -> Matrix_8 {
    var m: Matrix_8
    m.valid = true
    m.rows[0][0] = v
    return m
}
var mat: Matrix_8 = getMatrix(800)
println(mat.valid)
println(mat.rows[0][0])
