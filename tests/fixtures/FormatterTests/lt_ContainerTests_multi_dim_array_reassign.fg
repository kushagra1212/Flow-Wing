/; from LatestTests/ContainerTests/multi_dim_array_reassign.fg
var x:[2][3] = [[1, 2, 3], ["Hello", "World", 1.2]]
println(x)
var j:int[2][3] = [[1, 2, 3], x[0]]
println(j)
x = j
println(x)
println(j)
x[1] = ["Test", "World", "Test"]
j[1] = [1, 2, 3]
println(x)
println(j)
x[1][1] = 3.5
j[1][1] = 3
println(x)
println(j)
