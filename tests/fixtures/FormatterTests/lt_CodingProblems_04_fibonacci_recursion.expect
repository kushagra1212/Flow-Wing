/; from LatestTests/CodingProblems/04_fibonacci_recursion.fg
fun fibonacci(n: int) -> int {
    if (n == 0) {
        return 0
    }
    if (n == 1) {
        return 1
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}
println(fibonacci(10))
println(fibonacci(0))
println(fibonacci(1))
println("done")
