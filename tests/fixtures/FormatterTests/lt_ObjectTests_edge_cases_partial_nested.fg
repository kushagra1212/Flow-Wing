/; from LatestTests/ObjectTests/edge_cases/partial_nested.fg
type Address = {
    street: str
    city: str
    zip: int
}

type Person = {
    name: str
    age: int
    address: Address
}

type PartialAddress = {
    street: str
    city: str
}

type PartialPerson = {
    name: str
    address: PartialAddress
}

var partial: PartialPerson = {
    name: "Alice",
    address: {
        street: "456 Oak Ave",
        city: "Boston"
    }
}

var full: Person

print("Before assignment:\n")
print("partial: ", partial, "\n")
print("full: ", full, "\n")

full = partial

print("After assignment:\n")
print("partial: ", partial, "\n")
print("full: ", full, "\n")

