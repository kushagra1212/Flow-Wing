type Matrix_14 = {
    rows: int[15][2]
    valid: bool
}
fun getMatrix(v: int) -> Matrix_14 {
    var m: Matrix_14
    m.valid = true
    m.rows[0][0] = v
    return m
}
var mat: Matrix_14 = getMatrix(1400)
println(mat.valid)
