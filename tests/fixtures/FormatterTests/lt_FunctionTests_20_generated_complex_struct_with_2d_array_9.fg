type Matrix_9 = { rows: int[10][2], valid: bool }
fun getMatrix(v: int) -> Matrix_9 {
    var m: Matrix_9
    m.valid = true
    m.rows[0][0] = v
    return m
}

var mat: Matrix_9 = getMatrix(900)
println(mat.valid)
println(mat.rows[0][0])
