/; from LatestTests/ObjectTests/edge_cases/nested_objects.fg
type Address = {
    street: str
    city: str
}
type Person = {
    name: str
    age: int
    address: Address
}
var p: Person = {
    name: "John",
    age: 30,
    address: {
        street: "123 Main St",
        city: "New York"
    }
}
print(p, "\n")
