type Matrix_11 = {
    rows: int[12][2]
    valid: bool
}
fun getMatrix(v: int) -> Matrix_11 {
    var m: Matrix_11
    m.valid = true
    m.rows[0][0] = v
    return m
}
var mat: Matrix_11 = getMatrix(1100)
println(mat.valid)
println(mat.rows[0][0])
