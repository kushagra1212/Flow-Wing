type Matrix_1 = {
    rows: int[2][2]
    valid: bool
}
fun getMatrix(v: int) -> Matrix_1 {
    var m: Matrix_1
    m.valid = true
    m.rows[0][0] = v
    return m
}
var mat: Matrix_1 = getMatrix(100)
println(mat.valid)
println(mat.rows[0][0])
