/; from LatestTests/ObjectTests/edge_cases/linked_list_operations.fg
type Node = {
    value: int
    next: Node
}

var node1: Node = {
    value: 1,
    next: null
}

var node2: Node = {
    value: 2,
    next: node1
}

print("node1: ", node1, "\n")
print("node2: ", node2, "\n")

node1.next = node2

print("node1: ", node1, "\n")
print("node2: ", node2, "\n")

node1 = {
    value: 1,
    next: {
        value: 2,
        next: {
            value: 3
        }
    }
}

print("node1: ", node1, "\n")

node1 = {
    value: 1,
    next: {
        value: 2,
        next: {
            value: 3,
            next: {
                value: 4
            }
        }
    }
}

print("node1: ", node1, "\n")
