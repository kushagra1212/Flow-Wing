/; from LatestTests/ContainerTests/multi_dim_dynamic_array_complex.fg
var x:[2][3] = [[1, 2, 3], ["Hello", "World", "Test"]]
println("x = ", x)
var j:int[2][3] = [[1, 2, 3], x[0]]
println("j = ", j)
x = j
println("x = ", x)
println("j = ", j)
x[1] = ["Test", "World", "Test"]
j[1] = [1, 2, 3]
println("x = ", x)
println("j = ", j)
x[1][1] = 3.5
j[1][1] = 3
println("x = ", x)
println("j = ", j)
x[1] = j[1]
println("x = ", x)
println("j = ", j)
x[1][1] = 22
println("x = ", x)
println("j = ", j)
