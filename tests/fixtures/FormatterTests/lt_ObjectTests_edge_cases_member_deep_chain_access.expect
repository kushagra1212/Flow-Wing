/; from LatestTests/ObjectTests/edge_cases/member_deep_chain_access.fg
type Node = {
    value: int
    next: Node
}
var nodeDefault: Node
print("nodeDefault: ", nodeDefault, "\n")
var node1: Node = {value: 1}
var node2: Node = {value: 2}
print("node1: ", node1, "\n")
print("node2: ", node2, "\n")
var node3: Node = {
    value: 3,
    next: node1
}
print("node3: ", node3, "\n")
node1.next = node3
node2.next = node1
print("node1: ", node1, "\n")
print("node2: ", node2, "\n")
print("node3: ", node3, "\n")
print("node1: ", node1, "\n")
print("node1.next.next: ", node1.next.next, "\n")
