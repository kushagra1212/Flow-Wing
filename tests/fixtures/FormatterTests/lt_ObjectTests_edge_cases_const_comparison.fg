/; from LatestTests/ObjectTests/edge_cases/const_comparison.fg
type Person = {
    name: str
    age: int
}

const p1: Person = {
    name: "Alice",
    age: 30
}

const p2: Person = {
    name: "Bob",
    age: 25
}

print("p1.age > p2.age: ", p1.age > p2.age, "\n")
print("p1.name == p2.name: ", p1.name == p2.name, "\n")
print("p1 == p2: ", p1 == p2, "\n")
