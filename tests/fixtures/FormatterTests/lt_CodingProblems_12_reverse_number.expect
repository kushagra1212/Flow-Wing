/; from LatestTests/CodingProblems/12_reverse_number.fg
fun reverseNum(n: int) -> int {
    var rev: int = 0
    var x: int = n
    while (x > 0) {
        rev = rev * 10 + (x % 10)
        x = x // 10
    }
    return rev
}
println(reverseNum(123))
println(reverseNum(121))
println(reverseNum(1))
println("done")
