/; from LatestTests/IfStatementTests/05_complex/func_call_in_nested_condition.fg
fun isPos(x: int) -> bool {
    return x > 0
}
fun getVal() -> int {
    return 7
}
if (isPos(getVal())) {
    if (getVal() > 5) {
        println("pos and gt5")
    } else {
        println("pos and le5")
    }
} else {
    println("non-pos")
}
