type Matrix_10 = { rows: int[11][2], valid: bool }
fun getMatrix(v: int) -> Matrix_10 {
    var m: Matrix_10
    m.valid = true
    m.rows[0][0] = v
    return m
}

var mat: Matrix_10 = getMatrix(1000)
println(mat.valid)
println(mat.rows[0][0])
