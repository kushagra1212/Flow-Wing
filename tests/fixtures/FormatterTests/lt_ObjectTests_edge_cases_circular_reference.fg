/; from LatestTests/ObjectTests/edge_cases/circular_reference.fg
type Node = {
    value: int
    next: Node
}

var node1: Node = {
    value: 1
}

var node2: Node = {
    value: 2
}

print("node1: ", node1, "\n")
print("node2: ", node2, "\n")

node1.next = node2

print("node1.next: ", node1.next, "\n")

node2.next = node1

print("node2.next: ", node2.next, "\n")

print("After circular assignment:\n")
print("node1: ", node1, "\n")
print("node2: ", node2, "\n")
print("node1.next: ", node1.next, "\n")
print("node2.next: ", node2.next, "\n")

