print("Int to String Conversion\n")
print(String(1), "\n")
print(String(3), "\n")
print(String(0), "\n")

print("Double to String Conversion\n")
print(String(1.0), "\n")
print(String(3.0), "\n")
print(String(2.5), "\n")
print(String(0.0), "\n")

print("Float to String Conversion\n")
print(String(1.0f), "\n")
print(String(3.0f), "\n")
print(String(2.5f), "\n")
print(String(0.0f), "\n")

print("Char to String Conversion\n")
print(String('a'), "\n" )
print(String('b'), "\n")
print(String('0'), "\n")

print("Bool to String Conversion\n")
print(String(true), "\n")
print(String(false), "\n")
