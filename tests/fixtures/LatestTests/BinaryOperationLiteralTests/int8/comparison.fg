print("Int8 Comparison Tests\n")
print("Equality:\n")
print(0 == 0, "\n")
print(1 == 1, "\n")
print(1 == 0, "\n")
print(127 == 127, "\n")
print(-128 == -128, "\n")
print("Inequality:\n")
print(0 != 0, "\n")
print(1 != 0, "\n")
print(127 != -128, "\n")
print("Less Than:\n")
print(0 < 1, "\n")
print(1 < 0, "\n")
print(-128 < 127, "\n")
print("Less Than or Equal:\n")
print(0 <= 0, "\n")
print(0 <= 1, "\n")
print(1 <= 0, "\n")
print("Greater Than:\n")
print(1 > 0, "\n")
print(0 > 1, "\n")
print(127 > -128, "\n")
print("Greater Than or Equal:\n")
print(0 >= 0, "\n")
print(1 >= 0, "\n")
print(0 >= 1, "\n")

