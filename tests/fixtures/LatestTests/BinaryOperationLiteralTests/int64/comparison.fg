print("Int64 Comparison Tests\n")
print("Equality:\n")
print(3000000000 == 3000000000, "\n")
print(3000000000 == 3000000001, "\n")
print("Inequality:\n")
print(3000000000 != 3000000000, "\n")
print(3000000000 != 3000000001, "\n")
print("Less Than:\n")
print(3000000000 < 3000000001, "\n")
print(3000000001 < 3000000000, "\n")
print("Less Than or Equal:\n")
print(3000000000 <= 3000000000, "\n")
print(3000000000 <= 3000000001, "\n")
print("Greater Than:\n")
print(3000000001 > 3000000000, "\n")
print(3000000000 > 3000000001, "\n")
print("Greater Than or Equal:\n")
print(3000000000 >= 3000000000, "\n")
print(3000000001 >= 3000000000, "\n")

