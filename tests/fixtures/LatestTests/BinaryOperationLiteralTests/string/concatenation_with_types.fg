print("String Concatenation with Other Types Tests\n")
print("Value: " + 42, "\n")
print("Value: " + -42, "\n")
print("Value: " + 3.14, "\n")
print("Value: " + 3.14f, "\n")
print("Value: " + true, "\n")
print("Value: " + false, "\n")
print(42 + " is the answer", "\n")
print(-42 + " is negative", "\n")
print(3.14 + " is pi", "\n")
print(3.14f + " is float pi", "\n")
print(true + " is true", "\n")
print(false + " is false", "\n")

