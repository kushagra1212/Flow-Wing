print("Deci (Double) Division Tests\n")
print(0.0 / 1.0, "\n")
print(1.0 / 1.0, "\n")
print(6.0 / 2.0, "\n")
print(5.0 / 2.0, "\n")
print(10.0 / 3.0, "\n")
print(-6.0 / 2.0, "\n")
print(6.0 / -2.0, "\n")
print(-6.0 / -2.0, "\n")
print(3.14159265359 / 2.0, "\n")
print(1.0 / 4.0, "\n")
print(22.0 / 7.0, "\n")

