print("Int32 and Int64 Mixed Operations\n")
print("Addition:\n")
print(1000000 + 3000000000, "\n")
print(3000000000 + 1000000, "\n")
print(2147483647 + 3000000000, "\n")
print("Subtraction:\n")
print(1000000 - 3000000000, "\n")
print(3000000000 - 1000000, "\n")
print("Multiplication:\n")
print(1000 * 3000000000, "\n")
print(-1000 * 3000000000, "\n")
print("Division:\n")
print(1000000 / 3000000000, "\n")
print(3000000000 / 1000000, "\n")
print("Integer Division:\n")
print(1000000 // 3000000000, "\n")
print(3000000000 // 1000000, "\n")
print("Modulo:\n")
print(1000000 % 3000000000, "\n")
print(3000000000 % 1000000, "\n")

