print("Int and Double Mixed Operations\n")
print("Addition:\n")
print(1 + 1.5, "\n")
print(1.5 + 1, "\n")
print(10 + 0.5, "\n")
print(0.5 + 10, "\n")
print("Subtraction:\n")
print(5 - 1.5, "\n")
print(5.5 - 2, "\n")
print("Multiplication:\n")
print(2 * 1.5, "\n")
print(1.5 * 2, "\n")
print("Division:\n")
print(5 / 2.0, "\n")
print(5.0 / 2, "\n")

