print("Mixed Integer Bitwise Tests\n")
print("Int8 & Int32:\n")
print(15 & 255, "\n")
print(255 & 15, "\n")
print(127 & 128, "\n")
print("Int8 | Int32:\n")
print(15 | 256, "\n")
print(256 | 15, "\n")
print(127 | 128, "\n")
print("Int8 ^ Int32:\n")
print(15 ^ 255, "\n")
print(255 ^ 15, "\n")
print(127 ^ 128, "\n")
print("Int32 & Int64:\n")
print(255 & 3000000000, "\n")
print(3000000000 & 255, "\n")
print("Int32 | Int64:\n")
print(255 | 3000000000, "\n")
print(3000000000 | 255, "\n")

