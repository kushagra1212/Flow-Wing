print("Int and Float Mixed Operations\n")
print("Addition:\n")
print(1 + 1.5f, "\n")
print(1.5f + 1, "\n")
print(10 + 0.5f, "\n")
print(0.5f + 10, "\n")
print("Subtraction:\n")
print(5 - 1.5f, "\n")
print(5.5f - 2, "\n")
print("Multiplication:\n")
print(2 * 1.5f, "\n")
print(1.5f * 2, "\n")
print("Division:\n")
print(5 / 2.0f, "\n")
print(5.0f / 2, "\n")

