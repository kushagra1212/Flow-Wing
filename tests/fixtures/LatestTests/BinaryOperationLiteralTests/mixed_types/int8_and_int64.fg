print("Int8 and Int64 Mixed Operations\n")
print("Addition:\n")
print(10 + 3000000000, "\n")
print(3000000000 + 10, "\n")
print(127 + 3000000000, "\n")
print(-128 + 3000000000, "\n")
print("Subtraction:\n")
print(10 - 3000000000, "\n")
print(3000000000 - 10, "\n")
print("Multiplication:\n")
print(10 * 3000000000, "\n")
print(-10 * 3000000000, "\n")
print("Division:\n")
print(10 / 3000000000, "\n")
print(3000000000 / 10, "\n")
print("Integer Division:\n")
print(10 // 3000000000, "\n")
print(3000000000 // 10, "\n")
print("Modulo:\n")
print(10 % 3000000000, "\n")
print(3000000000 % 10, "\n")

