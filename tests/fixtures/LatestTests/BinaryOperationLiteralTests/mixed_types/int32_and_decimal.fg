print("Int32 and Decimal Mixed Operations\n")
print("Int32 + Double:\n")
print(1000 + 1.5, "\n")
print(1.5 + 1000, "\n")
print(-1000 + 1.5, "\n")
print("Int32 + Float:\n")
print(1000 + 1.5f, "\n")
print(1.5f + 1000, "\n")
print(-1000 + 1.5f, "\n")
print("Int32 - Double:\n")
print(1000 - 1.5, "\n")
print(1.5 - 1000, "\n")
print("Int32 * Double:\n")
print(1000 * 1.5, "\n")
print(1.5 * 1000, "\n")
print("Int32 / Double:\n")
print(1000 / 1.5, "\n")
print(1.5 / 1000, "\n")

