print("Mixed Integer Comparison Tests\n")
print("Int8 vs Int32:\n")
print(10 == 1000, "\n")
print(10 != 1000, "\n")
print(10 < 1000, "\n")
print(1000 < 10, "\n")
print(10 <= 1000, "\n")
print(10 > 1000, "\n")
print(1000 > 10, "\n")
print(10 >= 1000, "\n")
print("Int8 vs Int64:\n")
print(10 == 3000000000, "\n")
print(10 < 3000000000, "\n")
print(3000000000 > 10, "\n")
print("Int32 vs Int64:\n")
print(1000000 == 3000000000, "\n")
print(1000000 < 3000000000, "\n")
print(3000000000 > 1000000, "\n")

