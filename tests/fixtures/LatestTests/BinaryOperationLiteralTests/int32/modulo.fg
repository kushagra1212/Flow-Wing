print("Int32 Modulo Tests (values outside int8 range)\n")
print(128 % 1, "\n")
print(128 % 10, "\n")
print(1000 % 7, "\n")
print(10000 % 17, "\n")
print(1000000 % 1001, "\n")
print(-129 % 10, "\n")
print(-1000 % 7, "\n")
print(-1000 % -7, "\n")
print(2147483647 % 10, "\n")
print(1000000000 % 7, "\n")
