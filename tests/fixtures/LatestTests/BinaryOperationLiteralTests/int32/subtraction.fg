print("Int32 Subtraction Tests (values outside int8 range)\n")
print(128 - 0, "\n")
print(256 - 128, "\n")
print(3000 - 1000, "\n")
print(100000 - 50000, "\n")
print(1000000 - 500000, "\n")
print(-129 - 1, "\n")
print(-500 - 300, "\n")
print(-1000 - -2000, "\n")
print(2147483647 - 0, "\n")
print(-2147483648 - 0, "\n")
print(2000000000 - 1000000000, "\n")
