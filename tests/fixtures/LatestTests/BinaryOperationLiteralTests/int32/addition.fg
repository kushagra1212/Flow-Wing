print(128 + 128, "\n")
print(1000 + 2000, "\n")
print(50000 + 50000, "\n")
print(1000000 + 1000000, "\n")
print(-129 + 1, "\n")
print(-500 + 300, "\n")
print(-1000 + -2000, "\n")
print(2147483647 + 0, "\n")
