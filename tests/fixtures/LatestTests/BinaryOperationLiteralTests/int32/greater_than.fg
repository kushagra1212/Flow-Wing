print("Int32 Greater Than Tests (values outside int8 range)\n")
print(128 > 128, "\n")
print(128 > 129, "\n")
print(129 > 128, "\n")
print(1000 > 2000, "\n")
print(2000 > 1000, "\n")
print(-129 > 128, "\n")
print(128 > -129, "\n")
print(-500 > -1000, "\n")
print(-1000 > -500, "\n")
print(2000000 > 1000000, "\n")
