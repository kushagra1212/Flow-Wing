print("Int32 Integer Division Tests (values outside int8 range)\n")
print(128 // 1, "\n")
print(256 // 2, "\n")
print(1000 // 3, "\n")
print(10000 // 7, "\n")
print(1000000 // 1000, "\n")
print(-129 // 2, "\n")
print(-1000 // 3, "\n")
print(-1000 // -3, "\n")
print(2147483647 // 2, "\n")
print(1000000000 // 7, "\n")
