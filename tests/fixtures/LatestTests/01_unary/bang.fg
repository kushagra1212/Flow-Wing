print("Bang Prefix Operator for Int\n")
print(!1 , "\n")
print(!3 , "\n")
print(!0, "\n")

print("Bang Prefix Operator for Double\n")
print(!1.0 , "\n")
print(!3.0 , "\n")
print(!2.5 , "\n")
print(!0.0 , "\n")

print("Bang Prefix Operator for Float\n")
print(!1.0f , "\n")
print(!3.0f , "\n")
print(!2.5f , "\n")
print(!0.0f , "\n")

print("Bang Prefix Operator for String\n")
print(!"Hello" , "\n")
print(!"World" , "\n")
print(!("Hello" + "World") , "\n")
print(!("Hello" != "World") , "\n")
print(!"" , "\n")

print("Bang Prefix Operator for Boolean\n")
print(!true , "\n")
print(!false , "\n")
print(!(true && false) , "\n")
print(!(true || false) , "\n")
print(!(true && true) , "\n")
print(!(true || true) , "\n")
print(!(false && false) , "\n")
print(!(false || false) , "\n")
print(!(false && true) , "\n")
print(!(false || true) , "\n")

print("Bang Prefix Operator for Char\n")
print(!'a' , '\n')
print(!'b' , '\n')
print(!('a' + 'b') , '\n')
print(!('a' != 'b') , '\n')
print(!('a' == 'b') , '\n')
print(!('a' != 'a') , '\n')
print(!('a' == 'a') , '\n')
print(!('a' != 'b') , '\n')

print("Bang Prefix Operator for Nir\n")
print(!null , '\n')


print("Bang Bang Prefix Operator for Int\n")
print(!(!1) , '\n')
print(!(!3) , '\n')
print(!(!0) , '\n')

print("Bang Bang Prefix Operator for Double\n")
print(!(!1.0) , '\n')
print(!(!3.0) , '\n')
print(!(!2.5) , '\n')
print(!(!0.0) , '\n')
