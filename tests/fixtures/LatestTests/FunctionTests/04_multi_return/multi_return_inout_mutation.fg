fun test2(inout a: int, b: str = "Hello") -> int, deci {
  println("Hello World", a, b)
  a = 20
  println("Hello World", a, b)
  return 1, 3.5
}

var a: int = 10
var b: int = 33
println(a)
println(b)
var x: int, y: deci, c: deci32, x1: int, y1: deci, c1: deci32 = test2(a, "hello2"), 2.2f, test2(b, "hello3")
println(a)
println(x)
println(y)
println(c)
println(x1)
println(y1)
println(c1)
