type P_4 = { x: int, y: int }
type Shape_4 = { pts: P_4[2], id: int }
fun mod_4(inout s: Shape_4[2]) {
  s[0].pts[0].x = 40
  s[1].id = 400
}
var shapes_4: Shape_4[2] = [
  {pts: [{x: 0, y: 1}, {x: 2, y: 3}], id: 1},
  {pts: [{x: 4, y: 5}, {x: 6, y: 7}], id: 2}
]
mod_4(shapes_4)
println(shapes_4[0].pts[0].x)
println(shapes_4[1].id)
