type P_2 = { x: int, y: int }
type Shape_2 = { pts: P_2[2], id: int }
fun mod_2(inout s: Shape_2[2]) {
  s[0].pts[0].x = 20
  s[1].id = 200
}
var shapes_2: Shape_2[2] = [
  {pts: [{x: 0, y: 1}, {x: 2, y: 3}], id: 1},
  {pts: [{x: 4, y: 5}, {x: 6, y: 7}], id: 2}
]
mod_2(shapes_2)
println(shapes_2[0].pts[0].x)
println(shapes_2[1].id)
