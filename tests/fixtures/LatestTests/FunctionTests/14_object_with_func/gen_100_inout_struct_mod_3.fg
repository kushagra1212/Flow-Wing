type P_3 = { x: int, y: int }
type Shape_3 = { pts: P_3[2], id: int }
fun mod_3(inout s: Shape_3[2]) {
  s[0].pts[0].x = 30
  s[1].id = 300
}
var shapes_3: Shape_3[2] = [
  {pts: [{x: 0, y: 1}, {x: 2, y: 3}], id: 1},
  {pts: [{x: 4, y: 5}, {x: 6, y: 7}], id: 2}
]
mod_3(shapes_3)
println(shapes_3[0].pts[0].x)
println(shapes_3[1].id)
