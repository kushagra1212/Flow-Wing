type T = {
  a:int 
}

class A{
  var obj:T 

  init(obj:T) -> nthg {
    self.obj = obj 
  }
}


fun getA() -> A {
var d:A= new A({a:100})

 d.obj.a = 21
  return d
}

fun getAA() -> A {
  return getA()
}

