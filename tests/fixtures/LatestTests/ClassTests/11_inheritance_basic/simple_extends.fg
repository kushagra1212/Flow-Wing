class A {
  var x: int
  fun init(x: int) -> nthg {
    self.x = x
  }
  fun getX() -> int {
    return self.x
  }
}

class B extends A {
  var y: int
  fun init(x: int, y: int) -> nthg {
    self.x = x
    self.y = y
  }
  fun getY() -> int {
    return self.y
  }
}

var b: B = new B(10, 20)
println(b.getX())
println(b.getY())
