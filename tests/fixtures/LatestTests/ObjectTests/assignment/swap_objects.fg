type Person = {
    name: str
    age: int
}

var p1: Person = {
    name: "Alice",
    age: 20
}

var p2: Person = {
    name: "Bob",
    age: 25
}

var temp: Person

print("Before swap:\n")
print("p1: ", p1, "\n")
print("p2: ", p2, "\n")

temp = p1
p1 = p2
p2 = temp

print("After swap:\n")
print("p1: ", p1, "\n")
print("p2: ", p2, "\n")
print("temp: ", temp, "\n")

