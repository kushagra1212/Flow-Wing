type Person = {
    name: str
    age: int
}

var p1: Person = {
    name: "John",
    age: 30
}

var p2: Person = {
    name: "Jane",
    age: 25
}

print("Before assignment:\n")
print("p1: ", p1, "\n")
print("p2: ", p2, "\n")

p1 = p2

print("After assignment:\n")
print("p1: ", p1, "\n")
print("p2: ", p2, "\n")

