type Node = {
    value: int
    next: Node
}

var node1: Node = {
    value: 1,
    next: null
}

var node2: Node = {
    value: 2,
    next: node1
}

print("node1: ", node1, "\n")
print("node2: ", node2, "\n")

print("node1 == node2: ", node1 == node2, "\n")
print("node1 != node2: ", node1 != node2, "\n")

print("node1.next == node2.next: ", node1.next == node2.next, "\n")
print("node1.next != node2.next: ", node1.next != node2.next, "\n")

print("node2.next == node1: ", node2.next == node1, "\n")
print("node2.next != node1: ", node2.next != node1, "\n")

print("node1.next == node2: ", node1.next == node2, "\n")
print("node1.next != node2: ", node1.next != node2, "\n")
