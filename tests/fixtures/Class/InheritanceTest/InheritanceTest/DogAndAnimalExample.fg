class Animal {
  var age:int 
  var species:str 
  init(age:int) -> nthg {
    self.age = age
  }
  getAge() -> int {
    return self.age
  }
  printSpecies() -> nthg { 
    print("Species: ",species)
  }
}
class Dog extends Animal {
   var breed:str 
  
  init(age:int) -> nthg {
    super(age)
  }

  getAge() ->int {
    return 7*self.age  
  }
  printBreed() -> nthg { 
    print("breed "+breed)
  }
}
fun printAge(a: Animal) ->nthg{
  print("I'm "+a.getAge()+" years old!\n")
}
fun main2() -> nthg {
  var animal:Animal = new Animal(2)
  var  dog:Dog = new Dog(2)

  printAge(animal) 
  printAge(dog) 
}

main2()
