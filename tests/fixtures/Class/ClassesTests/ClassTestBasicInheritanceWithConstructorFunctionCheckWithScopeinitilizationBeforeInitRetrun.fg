type T = {
    a:int 
}
class A {
var i:deci32
var x:int 
var s:str 
var t:T
var g:T[2]
init(s: str) -> nthg{
  self.s = s 
}

getT() -> T {
    return t  
  }

getTA() -> T[2] {
    return g
  }
}

fun printT(t: T) -> nthg {
  print(t)
}
fun printTAr(ta:T[2]) -> nthg {
    print(ta)
  }

var a:A = new A("Hello")

printT(a.getT())
printTAr(a.getTA())
