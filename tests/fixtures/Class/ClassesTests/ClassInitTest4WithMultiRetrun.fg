class A {
  var x:int 
  var b:str 
  init(x:int,b: str = "Hello" ) -> nthg {
      self.x = x
      print("init B ",x,b)
      self.b = b 
  }
  init(x:int) -> nthg {
      self.x = x
      self.b = "He"
  }
  test(a:int,b:int = 4,k:str ="Hello" ) -> int,deci  {
    print("a: "+a)
   print("\nb: "+b)
