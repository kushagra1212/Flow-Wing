print("Deci (Double) Subtraction Tests\n")
print(0.0 - 0.0, "\n")
print(1.0 - 0.0, "\n")
print(0.0 - 1.0, "\n")
print(3.0 - 1.5, "\n")
print(3.14159265359 - 2.71828182846, "\n")
print(-1.5 - 1.5, "\n")
print(-3.14 - -2.86, "\n")
print(100.25 - 200.75, "\n")
print(0.000002 - 0.000001, "\n")
print(1234567890.123456 - 1234567890.123456, "\n")

