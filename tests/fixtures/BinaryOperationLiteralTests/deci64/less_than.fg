print("Deci (Double) Less Than Tests\n")
print(0.0 < 0.0, "\n")
print(0.0 < 1.0, "\n")
print(1.0 < 0.0, "\n")
print(1.0 < 1.0, "\n")
print(3.14 < 3.15, "\n")
print(3.15 < 3.14, "\n")
print(-1.5 < 1.5, "\n")
print(1.5 < -1.5, "\n")
print(-2.0 < -1.0, "\n")
print(-1.0 < -2.0, "\n")
print(0.000001 < 0.000002, "\n")

