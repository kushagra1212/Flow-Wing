print("Deci32 (Float) Subtraction Tests\n")
print(0.0f - 0.0f, "\n")
print(1.0f - 0.0f, "\n")
print(0.0f - 1.0f, "\n")
print(3.0f - 1.5f, "\n")
print(3.14f - 2.86f, "\n")
print(-1.5f - 1.5f, "\n")
print(-3.14f - -2.86f, "\n")
print(100.25f - 200.75f, "\n")
print(0.002f - 0.001f, "\n")
print(1234.5678f - 1234.5678f, "\n")

