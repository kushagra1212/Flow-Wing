print("Float and Double Mixed Operations\n")
print("Addition:\n")
print(1.5f + 1.5, "\n")
print(1.5 + 1.5f, "\n")
print("Subtraction:\n")
print(5.5f - 1.5, "\n")
print(5.5 - 1.5f, "\n")
print("Multiplication:\n")
print(2.0f * 1.5, "\n")
print(2.0 * 1.5f, "\n")
print("Division:\n")
print(5.0f / 2.0, "\n")
print(5.0 / 2.0f, "\n")

