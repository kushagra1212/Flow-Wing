print("Int8 and Int32 Mixed Operations\n")
print("Addition:\n")
print(10 + 1000, "\n")
print(1000 + 10, "\n")
print(127 + 128, "\n")
print(-128 + 1000, "\n")
print("Subtraction:\n")
print(10 - 1000, "\n")
print(1000 - 10, "\n")
print(127 - 128, "\n")
print("Multiplication:\n")
print(10 * 1000, "\n")
print(100 * 100, "\n")
print(-10 * 1000, "\n")
print("Division:\n")
print(10 / 1000, "\n")
print(1000 / 10, "\n")
print("Integer Division:\n")
print(10 // 1000, "\n")
print(1000 // 10, "\n")
print("Modulo:\n")
print(10 % 1000, "\n")
print(1000 % 10, "\n")

