print("Int32 Equality Tests (values outside int8 range)\n")
print(128 == 128, "\n")
print(128 == 129, "\n")
print(1000 == 1000, "\n")
print(1000 == 1001, "\n")
print(-129 == -129, "\n")
print(-129 == 129, "\n")
print(1000000 == 1000000, "\n")
print(2147483647 == 2147483647, "\n")
print(-2147483648 == -2147483648, "\n")
