for var i = 0 to 5 : 2 { 
          var j = 0 
          while j <= 5 { 
            if j == 2 { 
              j = j + 2 
              continue 
            } or if j == 2 { 
              print(j) 
            } else { 
              print(j) 
            } 
            j = j + 2 
          }
      }
