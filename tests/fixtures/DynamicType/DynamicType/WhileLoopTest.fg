var x = 'a'
while x < 'c' {
  print(x, " ")
  x = 'c' 
}
print("\n")
{
  var x: int = 0
  while x < 10 {
    print(x, " ")
    x = x + 1 
  }
}
print("\n")
{
  var x = 0
  while x < 10 {
    print(x, " ")
    x = x + 1 
  }
}
print("\n")
{
  var x = 0.0
  while x < 10 {
    print(x, " ")
    x = x + 1 
  }
}
