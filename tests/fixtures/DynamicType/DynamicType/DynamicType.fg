var x: int = 2
print(x, "\n")
var y = 3
print(y, "\n")
y = 5 
print(y, "\n")
y = x + 5 
print(y, "\n")
y = "Hello" 
print(y, "\n")
var z = 2
print(z, "\n")
y = y + z 
print(y, "\n")
var j = 5
print(j, "\n")
y = y + j 
y = y + 2 
y = y + "Hello" 
print(y, "\n")
var k: int[5] = [1, 2, 3, 4, y]
print(k, "\n")
var p = 45
print(p, "\n")
var arr: int[5] = [p, 2, p, 4, p]
print(arr, "\n")
