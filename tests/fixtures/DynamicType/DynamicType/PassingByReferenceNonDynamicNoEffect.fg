fun testFun(inout a) -> nthg {
  print(a, "\n")
  a = 30 
  print(a, "\n")
}

var x: int = 20
testFun(x)
print(x, "\n")
var y: str = "Hello"
testFun(y)
print(y, "\n")
var z: deci = 30.2
testFun(z)
print(z, "\n")
var w: deci32 = 30.2d
testFun(w)
print(w, "\n")
var v: bool = true
testFun(v)
print(v, "\n")
var u: bool = false
testFun(u)
print(u, "\n")
