print("Conversion to Int8 from String\n")
/; Wrap in () to force numeric output
print((Int8("98")), "\n") 

print("Conversion to Int8 from Float\n")
print((Int8(99.0f)), "\n")

print("Conversion to Int8 from Double\n")
print((Int8(120.0)), "\n")

print("Conversion to Int8 from Char\n")
print((Int8('a')), "\n")
print((Int8('z')), "\n")

print("Conversion to Int8 from \n")
print((Int8(121)), "\n")


print("Conversion to Int8 from String (Overflow)\n")
print((Int8("0")), "\n")
print((Int8("-1")), "\n")
print((Int8("12345678901234567890")), "\n")


print("Conversion to Int8 from Char\n")
print((Int8('{')), "\n")

print("Conversion to Int8 from Bool\n")
print((Int8(true)), "\n")
print((Int8(false)), "\n")

print("Conversion to Int8 from \n")
print((Int8(3)), "\n")