print("Conversion to Decimal from String\n")
print(Decimal("123"), "\n")
print(Decimal("0"), "\n")
print(Decimal("-1"), "\n")
print(Decimal("1234567890"), "\n")
print(Decimal("12345678901234567890"), "\n")
print(Decimal("123456789012345678901234567890"), "\n")
print(Decimal("1234567890123456789012345678901234567890"), "\n")
print(Decimal("12345678901234567890123456789012345678901234567890"), "\n")


print("Conversion to Decimal from Float\n")
print(Decimal(1.0f), "\n")
print(Decimal(3.0f), "\n")
print(Decimal(2.5f), "\n")
print(Decimal(0.0f), "\n")
print(Decimal(1.0f), "\n")
print(Decimal(3.3f), "\n")
print(Decimal(2.5f), "\n")
print(Decimal(0.0f), "\n")

print("Conversion to Decimal from Double\n")
print(Decimal(1.0), "\n")
print(Decimal(3.0), "\n")
print(Decimal(2.5), "\n")
print(Decimal(0.0), "\n")
print(Decimal(1.0), "\n")
print(Decimal(3.3), "\n")
print(Decimal(2.5), "\n")
print(Decimal(0.0), "\n")

print("Conversion to Decimal from Char\n")
print(Decimal('a'), "\n")

print("Conversion to Decimal from Bool\n")
print(Decimal(true), "\n")
print(Decimal(false), "\n")

print("Conversion to Decimal from Int\n")
print(Decimal(1), "\n")
print(Decimal(3), "\n")
print(Decimal(2), "\n")
print(Decimal(0), "\n")