print("Conversion to Bool from String\n")
print(Bool("false"), "\n")
print(Bool("true"), "\n")
print(Bool("0"), "\n")
print(Bool("1"), "\n")
print(Bool(""), "\n")
print(Bool(" "), "\n")
print(Bool("Hello"), "\n")
print(Bool("Hello World"), "\n")
print(Bool("Hello World"), "\n")


print("Conversion to Bool from Float\n")
print(Bool(1.0f), "\n")
print(Bool(3.0f), "\n")
print(Bool(2.5f), "\n")
print(Bool(0.0f), "\n")
print(Bool(1.0f), "\n")
print(Bool(3.3f), "\n")
print(Bool(2.5f), "\n")
print(Bool(0.0f), "\n")

print("Conversion to Bool from Double\n")
print(Bool(1.0), "\n")
print(Bool(3.0), "\n")
print(Bool(2.5), "\n")
print(Bool(0.0), "\n")
print(Bool(1.0), "\n")
print(Bool(3.3), "\n")
print(Bool(2.5), "\n")
print(Bool(0.0), "\n")

print("Conversion to Bool from Char\n")
print(Bool('a'), "\n")
print(Bool('b'), "\n")
print(Bool('c'), "\n")
print(Bool('d'), "\n")
print(Bool('e'), "\n")
print(Bool('f'), "\n")
print(Bool('g'), "\n")
print(Bool('h'), "\n")
print(Bool('i'), "\n")
print(Bool('j'), "\n")

print("Conversion to Bool from Bool\n")
print(Bool(true), "\n")
print(Bool(false), "\n")

print("Conversion to Bool from Int\n")
print(Bool(1), "\n")
print(Bool(3), "\n")
print(Bool(2), "\n")
