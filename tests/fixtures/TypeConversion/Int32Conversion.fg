print("Conversion to Int32 from String\n")
print(Int32("123"), "\n")
print(Int32("0"), "\n")
print(Int32("-1"), "\n")
print(Int32("1234567890"), "\n")
print(Int32("12345678901234567890"), "\n")
print(Int32("123456789012345678901234567890"), "\n")
print(Int32("1234567890123456789012345678901234567890"), "\n")
print(Int32("12345678901234567890123456789012345678901234567890"), "\n")


print("Conversion to Int32 from Float\n")
print(Int32(1.0f), "\n")
print(Int32(3.0f), "\n")
print(Int32(2.5f), "\n")
print(Int32(0.0f), "\n")
print(Int32(1.0f), "\n")
print(Int32(3.3f), "\n")
print(Int32(2.5f), "\n")
print(Int32(0.0f), "\n")

print("Conversion to Int32 from Double\n")
print(Int32(1.0), "\n")
print(Int32(3.0), "\n")
print(Int32(2.5), "\n")
print(Int32(0.0), "\n")
print(Int32(1.0), "\n")
print(Int32(3.3), "\n")
print(Int32(2.5), "\n")
print(Int32(0.0), "\n")

print("Conversion to Int32 from Char\n")
print(Int32('a'), "\n")

print("Conversion to Int32 from Bool\n")
print(Int32(true), "\n")
print(Int32(false), "\n")

print("Conversion to Int32 from Int\n")
print(Int32(1), "\n")
print(Int32(3), "\n")
print(Int32(2), "\n")
print(Int32(0), "\n")