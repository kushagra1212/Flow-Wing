print("Conversion to String from String\n")
print(String("Hello"), "\n")


print("Conversion to String from Float\n")
print(String(1.0f), "\n")
print(String(3.0f), "\n")
print(String(2.5f), "\n")
print(String(0.0f), "\n")
print(String(1.0f), "\n")
print(String(3.3f), "\n")
print(String(2.5f), "\n")
print(String(0.0f), "\n")

print("Conversion to String from Double\n")
print(String(1.0), "\n")
print(String(3.0), "\n")
print(String(2.5), "\n")
print(String(0.0), "\n")
print(String(1.0), "\n")
print(String(3.3), "\n")
print(String(2.5), "\n")
print(String(0.0), "\n")

print("Conversion to String from Char\n")
print(String('a'), "\n")

print("Conversion to String from Bool\n")
print(String(true), "\n")
print(String(false), "\n")

print("Conversion to String from Int\n")
print(String(1), "\n")
print(String(3), "\n")
print(String(2), "\n")
print(String(0), "\n")