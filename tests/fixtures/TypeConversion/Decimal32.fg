print("Conversion to Decimal32 from String\n")
print(Decimal32("123"), "\n")
print(Decimal32("0"), "\n")
print(Decimal32("-1"), "\n")
print(Decimal32("1234567890"), "\n")
print(Decimal32("12345678901234567890"), "\n")
print(Decimal32("123456789012345678901234567890"), "\n")
print(Decimal32("1234567890123456789012345678901234567890"), "\n")
print(Decimal32("12345678901234567890123456789012345678901234567890"), "\n")


print("Conversion to Decimal32 from Float\n")
print(Decimal32(1.0f), "\n")
print(Decimal32(3.0f), "\n")
print(Decimal32(2.5f), "\n")
print(Decimal32(0.0f), "\n")
print(Decimal32(1.0f), "\n")
print(Decimal32(3.3f), "\n")
print(Decimal32(2.5f), "\n")
print(Decimal32(0.0f), "\n")

print("Conversion to Decimal32 from Double\n")
print(Decimal32(1.0), "\n")
print(Decimal32(3.0), "\n")
print(Decimal32(2.5), "\n")
print(Decimal32(0.0), "\n")
print(Decimal32(1.0), "\n")
print(Decimal32(3.3), "\n")
print(Decimal32(2.5), "\n")
print(Decimal32(0.0), "\n")

print("Conversion to Decimal from Char\n")
print(Decimal32('a'), "\n")

print("Conversion to Decimal from Bool\n")
print(Decimal32(true), "\n")
print(Decimal32(false), "\n")

print("Conversion to Decimal from Int\n")
print(Decimal32(1), "\n")
print(Decimal32(3), "\n")
print(Decimal32(2), "\n")
print(Decimal32(0), "\n")