type T = {
  a:int 
}

class A{
  var obj:T 
  var r:int 
  var u:T 
  init(obj:T,r:int,u:T ) -> nthg {
    self.obj = obj 
  
    self.u =  u 
    self.r  =r
  }
}


fun getR() -> int {
    return 2 
  }
fun getU() -> T {
    return {a:53}
  }

fun getA() -> A {
  var x:A = new A({a:22},getR(),getU())

  return x 
}

var a:A = getA()
print(a.obj)
print(a.u)
print(a.r)
