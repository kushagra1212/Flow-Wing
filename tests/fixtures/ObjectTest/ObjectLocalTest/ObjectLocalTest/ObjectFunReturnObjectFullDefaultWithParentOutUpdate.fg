type parent ={
      pa:int,
      pb:str,
      pc:bool,
      pd:deci
}

type t1 = {
      a:str,
      b:int,
      c:bool,
      d:deci,
      par:parent
}
      var x:t1 = {
      }
      
fun get() -> t1 {

      x.a = "hello"
      x.b = 100
      x.c = true
      x.d = 10.0
      x.par = {pa:1,pb:"hello",pc:true,pd:10.0}
      return x
}
print(get())
