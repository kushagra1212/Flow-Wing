type parent = {
      pa:str,
      pb:int,
      pc:deci,
      pd:bool
     }

     type t1 = {
      a:str,
      b:int,
      c:deci,
      d:bool,
      p:parent
     }

    fun mainTest() -> parent {
          var x:t1 = { 
       a:"hello",
       b:10,
       c:10.10,
       d:true,
       p: {pa:"s",pb:1,pc:1.1,pd:true}
     }
    var y:t1 = x
    return y.p
    }

    {
            var z:parent =  mainTest()
     print(z)
    }
