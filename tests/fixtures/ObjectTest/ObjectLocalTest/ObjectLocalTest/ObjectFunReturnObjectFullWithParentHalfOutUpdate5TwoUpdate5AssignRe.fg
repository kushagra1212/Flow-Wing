type parent ={
      pa:int,
      pb:str,
      pc:bool,
      pd:deci
}

type t1 = {
      a:str,
      b:int,
      c:bool,
      d:deci,
      par:parent
}
fun get(y:t1) -> t1 {
      y.par.pa = 545
      y.par.pb = "llo"
      y.par.pc = true
      return y
}
var  x:t1 = {a:"hello",b:100,c:true,d:2.0,par:{pa:200,pb:"fso",pc:true,pd:3.0}}
var z:t1 = {a:"string",b:500,c:true,d:5.0,par:{pa:700,pb:"fdso",pc:true,pd:4.0}}
print(z)
z = get(x)
print(z)
