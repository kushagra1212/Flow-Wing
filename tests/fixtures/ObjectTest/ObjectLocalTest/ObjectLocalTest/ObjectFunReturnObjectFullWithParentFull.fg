type parent ={
      pa:int,
      pb:str,
      pc:bool,
      pd:deci
}

type t1 = {
      a:str,
      b:int,
      c:bool,
      d:deci,
      par:parent
}

fun get() -> t1 {
      var x:t1 = {
            a:"hello",
            b:100,
            c:true,
            d:2.0,
            par:{pa:100,pb:"hello",pc:true,pd:2.0}
      }
      
      return x
}
print(get())
