{
             type parent = {
      pa:str,
      pb:int,
      pc:deci,
      pd:bool
     }

     type t1 = {
      a:str,
      b:int,
      c:deci,
      d:bool,
      p:parent
     }

     var x:t1 = { 
       a:"hello",
       b:10,
       c:10.10,
       d:true,
       p:{ pa : "hello", pb : 2, pc : 45.00000000000000, pd : true }
     }

     print(x)
    {
           x.p = { pa : "w", pb : 2, pc : 45.00000000000000, pd : true }
     x.p.pa = "g"
     x.p.pd = false
     x.p.pb = 1
     x.p.pc = -1 * 45.10000000000000
    }
     print(x)
    }
