type parent ={
      pa:int,
      pb:str,
      pc:bool,
      pd:deci
}

type t1 = {
      a:str,
      b:int,
      c:bool,
      d:deci,
      par:parent
}
      var x:t1 = {
            a:"hello",
            b:100,
            c:true,
            d:2.0,
            par:{pa:100,pb:"hello",pc:true,pd:2.0}
      }
fun get() -> t1 {
      x.b = 200
      x.c = false
      x.d = 3.0
      x.par.pc = false
      x.par.pd = 3.0
      x.par.pa = 200
      
      return x
}
print(get())
