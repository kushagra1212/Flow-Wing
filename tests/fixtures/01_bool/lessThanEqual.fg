print("Boolean Less Than Equal\n")
print(true <= true, "\n")
print(true <= false, "\n")
print(false <= true, "\n")
print(false <= false, "\n")

print("Decimal Less Than Equal\n")
print(1.0 <= 1.0, "\n")
print(1.0 <= 2.0, "\n")
print(2.0 <= 1.0, "\n")
print(2.0 <= 2.0, "\n")

print("Int32 Less Than Equal\n")
print(2 <= 2, "\n")
print(2 <= 1, "\n")
print(1 <= 2, "\n")
print(1 <= 1, "\n")

print("String Less Than Equal\n")
print("Hello" <= "Hello", "\n")
print("abc" <= "abd", "\n")
print("a" <= "b", "\n")
print("a" <= "a", "\n")
print("da" <= "ab", "\n")
print("a" <= "da", "\n")
print("da" <= "da", "\n")
print("abc" <= "ab", "\n")

print("Character Less Than Equal\n")
print('a' <= 'a', "\n")
print('a' <= 'b', "\n")
print('b' <= 'a', "\n")
print('b' <= 'b', "\n")