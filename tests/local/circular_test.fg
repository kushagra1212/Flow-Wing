type Node = {
    value: int
    next: Node
}

var nodeDefault: Node 
print("nodeDefault: ", nodeDefault, "\n")
var node1: Node = {
    value: 1
}
var node2: Node = {
    value: 2
}

print("node1: ", node1, "\n")
print("node2: ", node2, "\n")

var node3: Node = {
    value: 3,
    next: node1
}

print("node3: ", node3, "\n")

node1.next = node3
node2.next = node1


print("node1: ", node1, "\n")
print("node2: ", node2, "\n")
print("node3: ", node3, "\n")


print("node1: ", node1, "\n")
print("node1.next.next: ", node1.next.next, "\n")

/; node1.next = Nir
print("node1: ", node1, "\n")
print("node1.next: ", node1.next, "\n")
print("node1.next.next: ", node1.next.next, "\n")

/;node2 = { value:100, next: Nir}
/; node2 = { value:100, next: { value:200 }    }
/; node2 = { value:100, next: node1    }
/; node2 = Nir

print("node2: ", node2, "\n")
print("node2.next: ", node2.next, "\n")





/; print("After circular assignment:\n")
/; print("node1: ", node1, "\n")
/; print("node2: ", node2, "\n")
/; print("node1.next: ", node1.next, "\n")
/; print("node2.next: ", node2.next, "\n")

