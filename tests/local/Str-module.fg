
fun strLength(str1: as str) -> as int decl
fun strToUpper(str1: as str) -> as str decl
fun strToLower(str1: as str) -> as str decl
fun strReverse(str1: as str) -> as str decl
fun strTrim(str1: as str) -> as str decl
fun strReplace(str1: as str, target: as str, replacement: as str) -> as str decl

module [fg]



fun getLength( str1: str) -> int {
    return strLength(str1)
}

fun toUpper( str1: str) -> str {
    return strToUpper(str1)
}

fun toLower( str1: str) -> str {
    return strToLower(str1)
}

fun reverse( str1: str) -> str {
    return strReverse(str1)
}

fun trim( str1: str) -> str {
    return strTrim(str1)
}

fun replace( str1: str, target: str, replacement: str) -> str {
    return strReplace(str1, target, replacement)
}


class Str {
  var _buffer: str
  var _len: int

  init(source: str) -> nthg {
    self._buffer = source
    self._len = getLength(source)
  }

  fun getLength() -> int {
    return self._len
  }

  fun toUpper() -> fg::Str {
    self._buffer = toUpper(self._buffer)
    return self
  }

  fun toLower() -> fg::Str {
    self._buffer = toLower(self._buffer)
    return self
  }

  fun reverse() -> fg::Str {
    self._buffer = reverse(self._buffer)
    return self
  } 

  fun trim() -> fg::Str {
    self._buffer = trim(self._buffer)
    return self
  }

  fun replace(target: str, replacement: str) -> fg::Str {
    self._buffer = replace(self._buffer, target, replacement)
    return self
  }

  fun get() -> str {
    return self._buffer
  }
}