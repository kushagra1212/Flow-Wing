/; print(x, "\n")

/; var x:bool = true
/; print(x, "\n")


/; var x:bool = false
/; print(x, "\n")

/; EXPECT_ERROR: InvalidBinaryOperationWithTypes
/; var x:bool = true + false
/; print(x, "\n")


/; var x:str = "Hello"
/; print(x, "\n")

