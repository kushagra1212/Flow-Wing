type Point = {
    x: int
    y: int
}

type Dummy = {
    x:int
}

var d1: Dummy = { x: 10 }

var p1: Point =d1
print("p1: ", p1, "\n")


type Point = {
    x: int
    y: int
}

type Dummy = {
    x:int
}

type T = {
    p: Point
    t: T
    d: int
}

var t1: T = { p: { x: 10, y: 20 }, t: {}, d: 10 }

print("t1: ", t1, "\n")

t1  = { p: { x: 100, y: 200 } }

print("t1: ", t1, "\n")


