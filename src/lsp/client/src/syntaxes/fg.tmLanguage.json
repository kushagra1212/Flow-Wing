{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "FlowWing",
  "scopeName": "source.fg",
  "fileTypes": ["fg"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#template-strings" },
    { "include": "#character-literals" },
    { "include": "#numbers" },
    { "include": "#attributes" },
    { "include": "#imports" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#type-declarations" },
    { "include": "#class-declarations" },
    { "include": "#type-references" },
    { "include": "#constants" },
    { "include": "#special-variables" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.fg",
          "match": "/;.*$"
        },
        {
          "name": "comment.block.fg",
          "begin": "/#",
          "end": "#/",
          "patterns": [{ "include": "#comments" }]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.fg",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.fg",
              "match": "\\\\[\\\\\"nrt0]"
            }
          ]
        }
      ]
    },
    "template-strings": {
      "patterns": [
        {
          "name": "string.quoted.template.fg",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.fg",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "character-literals": {
      "patterns": [
        {
          "name": "constant.character.fg",
          "begin": "'(?!')",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.fg",
              "match": "\\\\[\\\\'nrt0]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.fg",
          "match": "\\b\\d+\\.\\d+([dDfF])?\\b"
        },
        {
          "name": "constant.numeric.hex.fg",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.integer.fg",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "comment": "control flow",
          "name": "keyword.control.fg",
          "match": "\\b(if|else|for|while|break|continue|return|switch|case|default)\\b"
        },
        {
          "comment": "or if (two-word)",
          "name": "keyword.control.fg",
          "match": "\\bor\\s+if\\b"
        },
        {
          "comment": "declaration",
          "name": "keyword.declaration.fg",
          "match": "\\b(type|fun|var|const)\\b"
        },
        {
          "comment": "storage modifiers",
          "name": "storage.modifier.fg",
          "match": "\\b(inout|expose)\\b"
        },
        {
          "comment": "other keywords",
          "name": "keyword.other.fg",
          "match": "\\b(bring|from|module|class|extends|init|new|as|decl|fill|to)\\b"
        },
        {
          "comment": "operators - arrow",
          "name": "keyword.operator.arrow.fg",
          "match": "->"
        },
        {
          "comment": "operators - comparison",
          "name": "keyword.operator.comparison.fg",
          "match": "===|!==|==|!=|<=|>=|(?<![=!<>])<(?!<|=)|(?<![=!<>])>(?!>|=)"
        },
        {
          "comment": "operators - logical",
          "name": "keyword.operator.logical.fg",
          "match": "\\|\\||&&|!"
        },
        {
          "comment": "operators - bitwise",
          "name": "keyword.operator.bitwise.fg",
          "match": "\\^|\\||&|<<|>>"
        },
        {
          "comment": "operators - arithmetic",
          "name": "keyword.operator.arithmetic.fg",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "comment": "operators - assignment",
          "name": "keyword.operator.assignment.fg",
          "match": "=(?!=|>)"
        },
        {
          "comment": "operators - member access",
          "name": "keyword.operator.member.fg",
          "match": "\\.(?!\\.)"
        },
        {
          "comment": "operators - module access",
          "name": "keyword.operator.namespace.fg",
          "match": "::"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "keyword.control.import.fg",
          "match": "\\bbring\\b"
        },
        {
          "name": "keyword.control.import.fg",
          "match": "\\bfrom\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.fg",
          "match": "\\b(int8|int64|int|char|deci|deci32|str|bool|nthg|null)\\b"
        }
      ]
    },
    "type-declarations": {
      "patterns": [
        {
          "name": "meta.type.declaration.fg",
          "match": "\\btype\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.fg" }
          }
        }
      ]
    },
    "class-declarations": {
      "patterns": [
        {
          "name": "meta.class.declaration.fg",
          "begin": "\\bclass\\s+",
          "end": "(?=\\{)",
          "beginCaptures": {
            "0": { "name": "keyword.other.fg" }
          },
          "patterns": [
            { "include": "#comments" },
            {
              "name": "entity.name.type.class.fg",
              "match": "\\b([A-Z][A-Za-z0-9_]*)\\b"
            },
            {
              "name": "keyword.other.fg",
              "match": "\\bextends\\b"
            },
            {
              "name": "entity.other.inherited-class.fg",
              "match": "(?<=\\bextends\\s+)\\b([A-Z][A-Za-z0-9_]*)\\b"
            }
          ]
        }
      ]
    },
    "type-references": {
      "patterns": [
        {
          "comment": "type after colon in var/param: var x: Type",
          "name": "meta.type.annotation.fg",
          "match": ":\\s*([A-Z][A-Za-z0-9_]*(?:\\[\\d*\\])?)",
          "captures": {
            "1": { "name": "entity.name.type.fg" }
          }
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "comment": "function definition",
          "name": "meta.function.definition.fg",
          "match": "\\bfun\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.fg" }
          }
        },
        {
          "comment": "function call",
          "name": "entity.name.function.call.fg",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.fg",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.fg",
          "match": "\\bnull\\b"
        }
      ]
    },
    "special-variables": {
      "patterns": [
        {
          "name": "variable.language.self.fg",
          "match": "\\bself\\b"
        },
        {
          "name": "variable.language.super.fg",
          "match": "\\bsuper\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.fg",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.fg",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.fg",
          "match": ":"
        },
        {
          "name": "punctuation.definition.brackets.curly.fg",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.brackets.round.fg",
          "match": "[()]"
        },
        {
          "name": "punctuation.definition.brackets.square.fg",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.definition.brackets.angle.fg",
          "match": "(?<!=)[<>](?!=)"
        }
      ]
    },
    "attributes": {
      "name": "meta.attribute.fg",
      "begin": "(#)(!?)(\\[)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.attribute.fg" },
        "3": { "name": "punctuation.brackets.attribute.fg" }
      },
      "end": "\\]",
      "endCaptures": {
        "0": { "name": "punctuation.brackets.attribute.fg" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#strings" },
        { "include": "#types" }
      ]
    }
  }
}
