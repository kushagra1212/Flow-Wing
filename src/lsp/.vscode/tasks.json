{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"command": "yarn compile",
			"group": "build",
			"presentation": { "panel": "dedicated", "reveal": "never" },
			"problemMatcher": ["$tsc"]
		},
		{
			"type": "shell",
			"command": "yarn watch",
			"isBackground": true,
			"group": { "kind": "build", "isDefault": true },
			"presentation": { "panel": "dedicated", "reveal": "never" },
			"problemMatcher": ["$tsc-watch"]
		},
		{
			"label": "watch-lsp",
			"type": "shell",
			"command": "yarn watch",
			"options": { "cwd": "${workspaceFolder}/src/lsp" },
			"isBackground": true,
			"group": "build",
			"presentation": { "panel": "dedicated", "reveal": "never" },
			"problemMatcher": ["$tsc-watch"]
		}
	]
}