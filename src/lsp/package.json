{
  "name": "Flow-Wing",
  "displayName": "Flow-Wing",
  "description": "Language support for Flow-Wing (.fg): syntax highlighting, theme, IntelliSense, diagnostics, and format-on-save via the Flow-Wing compiler (VS Code, Cursor, VSCodium / Open VSX).",
  "author": "Kushagra Rathore",
  "license": "GPL-2.0-only",
  "version": "1.0.0",
  "homepage": "https://github.com/kushagra1212/Flow-Wing",
  "repository": {
    "type": "git",
    "url": "https://github.com/kushagra1212/Flow-Wing"
  },
  "bugs": {
    "url": "https://github.com/kushagra1212/Flow-Wing/issues"
  },
  "icon": "client/src/resources/icon.png",
  "publisher": "Kushagra",
  "categories": [
    "Programming Languages",
    "Themes",
    "Formatters"
  ],
  "keywords": [
    "flowwing",
    "flow-wing",
    "fg",
    "language server",
    "intellisense",
    "multi-root ready"
  ],
  "engines": {
    "vscode": "^1.52.0"
  },
  "activationEvents": [
    "onLanguage:flowwing"
  ],
  "main": "./client/out/extension",
  "contributes": {
    "languages": [
      {
        "id": "flowwing",
        "extensions": [
          ".fg"
        ],
        "configuration": "client/src/configuration/fg-configuration.json",
        "icon": {
          "dark": "client/src/resources/icon.png",
          "light": "client/src/resources/icon.png"
        }
      },
      {
        "id": "flowwing-markdown-injection"
      }
    ],
    "grammars": [
      {
        "language": "flowwing",
        "scopeName": "source.fg",
        "path": "client/src/syntaxes/fg.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Flow-Wing Dark",
        "uiTheme": "vs-dark",
        "path": "client/src/themes/flowwing-dark.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Flow-Wing",
      "properties": {
        "FlowWing.enable": {
          "scope": "resource",
          "type": "boolean",
          "default": true,
          "description": "Controls the enablement."
        },
        "FlowWing.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VSCode and the language server."
        },
        "FlowWing.maxNumberOfProblems": {
          "scope": "resource",
          "type": "number",
          "default": 100,
          "description": "Controls the maximum number of problems produced by the server."
        },
        "FlowWing.compilerPath": {
          "scope": "resource",
          "type": "string",
          "default": "FlowWing",
          "description": "Path to the Flow-Wing compiler executable (e.g. FlowWing if in PATH, or absolute path like ./build/sdk/bin/FlowWing)."
        },
        "FlowWing.modulePath": {
          "scope": "resource",
          "type": "string",
          "default": "",
          "description": "Path to the Flow-Wing modules (e.g. build/sdk/lib/modules). Leave empty to use workspace build output."
        }
      }
    },
    "configurationDefaults": {
      "[flowwing]": {
        "editor.formatOnSave": true
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "lint": "eslint ./client/src ./server/src --ext .ts,.tsx",
    "test": "npm run compile && cd server && npm test",
    "test:debug": "npm run compile && cd server && npm run test:debug",
    "postinstall": "cd client && npm install && cd ../server && npm install && cd .."
  },
  "devDependencies": {
    "@types/mocha": "^5.2.0",
    "@types/node": "^16.18.34",
    "@typescript-eslint/eslint-plugin": "^7.14.0",
    "@typescript-eslint/parser": "^7.14.0",
    "eslint": "^8.26.0",
    "typescript": "^5.5.2"
  }
}
